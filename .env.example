# Required: Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Optional: Second bot token (v2 runs both bots in one process)
# BOT_TOKEN_2=your_second_bot_token_here

# Optional: Database URL (default: SQLite in ./data/bot.db)
# SQLite:
# DATABASE_URL=sqlite:///./data/bot.db
# PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/botdb

# Optional: Minimum seconds between sends (rate limiting)
# MIN_SEND_INTERVAL_SECONDS=2.0

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
