[Unit]
Description=Telegram Auto Post 2
After=network.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/path/to/telegram-autopost-2
ExecStart=/path/to/venv/bin/python bot.py
Restart=always
RestartSec=10
# Do NOT set BOT_TOKEN/BOT_TOKEN_2 here - use .env in the app directory

[Install]
WantedBy=multi-user.target
